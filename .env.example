# Supabase (required) — project URL + anon/publishable key
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# GitHub token (optional) — dev fallback for the GitHub API when not signed in.
# After GitHub OAuth login, the session's provider token is used instead.
VITE_GITHUB_TOKEN=

# Target repository (optional) — defaults to yassineromdh-del/Hackathon-MISTRAL-Vibe
VITE_GITHUB_OWNER=
VITE_GITHUB_REPO=

# API base overrides (optional) — for GitHub Enterprise or a custom data proxy.
VITE_GITHUB_API_BASE=
VITE_WORKFLOW_FILE=

# ---------------------------------------------------------------------------
# APP BACKEND ONLY (app/server.py) — never VITE_-prefixed, never in the frontend.
# Set these where the App backend is deployed (Cloud Run/Fly secrets):
#   GITHUB_APP_ID=123456
#   GITHUB_APP_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...    # PEM contents
#   GITHUB_WEBHOOK_SECRET=your_webhook_secret
#   SUPABASE_URL=https://your-project-ref.supabase.co
#   SUPABASE_SERVICE_KEY=your_service_role_key                     # write — keep secret
#   # GitLab (optional):
#   GITLAB_TOKEN=glpat-...            # group access token (scope: api)
#   GITLAB_WEBHOOK_TOKEN=your_webhook_token
# ---------------------------------------------------------------------------
