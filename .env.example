# Supabase (required) — project URL + anon/publishable key
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# GitHub token (optional) — dev fallback for the GitHub API when not signed in.
# After GitHub OAuth login, the session's provider token is used instead.
VITE_GITHUB_TOKEN=

# Target repository (optional) — defaults to yassineromdh-del/Hackathon-MISTRAL-Vibe
VITE_GITHUB_OWNER=
VITE_GITHUB_REPO=
